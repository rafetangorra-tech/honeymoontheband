---
import { Image } from 'astro:assets';
import { url } from '~/lib/url';
import type { ImageMetadata } from 'astro';

interface Props {
  slug: string;
  name: string;
  role: string;
  image: ImageMetadata;
  teaser?: string;
}
const { slug, name, role, image, teaser } = Astro.props;
---

<a
  href={url(`/band/${slug}`)}
  class="group block bg-white border border-honey/15 hover:border-honey transition-colors"
>
  <div class="aspect-[4/5] overflow-hidden bg-espresso/5">
    <Image
      src={image}
      alt={`${name}, ${role}`}
      widths={[200, 400, 600, 800]}
      sizes="(min-width: 1024px) 280px, (min-width: 640px) 33vw, 50vw"
      formats={['avif', 'webp']}
      loading="lazy"
      class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
    />
  </div>
  <div class="p-5">
    <p class="eyebrow">{role}</p>
    <h3 class="mt-1 text-lg font-bold tracking-tight">{name}</h3>
    {teaser && <p class="mt-2 text-sm text-espresso/70 leading-snug">{teaser}</p>}
  </div>
</a>
