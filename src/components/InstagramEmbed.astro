---
interface Props {
  reelId: string;
}
const { reelId } = Astro.props;
const permalink = `https://www.instagram.com/reel/${reelId}/`;
---

<blockquote
  class="instagram-media w-full mx-auto"
  data-instgrm-captioned
  data-instgrm-permalink={`${permalink}?utm_source=ig_embed&utm_campaign=loading`}
  data-instgrm-version="14"
  style="background:#FFF; border:0; max-width:540px; min-width:280px; margin:0 auto; padding:0; width:100%;"
>
  <div style="padding:24px; text-align:center;">
    <a
      href={permalink}
      target="_blank"
      rel="noopener"
      style="color:#d7af70; font-weight:600; text-decoration:none; font-size:14px; letter-spacing:0.04em; text-transform:uppercase;"
    >
      View this reel on Instagram ↗
    </a>
  </div>
</blockquote>
