---
import { NAV, bookingMailto } from '~/data/site';
import { url } from '~/lib/url';

const { pathname } = Astro.url;
const isActive = (href: string) => {
  const full = url(href);
  return href === '/' ? pathname === full || pathname === full.replace(/\/$/, '') : pathname.startsWith(full);
};
---

<header class="border-b border-honey/20 bg-cream/95 backdrop-blur supports-[backdrop-filter]:bg-cream/80 sticky top-0 z-40">
  <div class="container-narrow flex items-center justify-between py-4">
    <a href={url('/')} class="flex items-center gap-3" aria-label="Honeymoon — home">
      <img
        src={url('/img/logo.png')}
        alt="Honeymoon"
        width="48"
        height="48"
        class="h-10 w-10 md:h-12 md:w-12"
      />
      <span class="font-bold tracking-[0.18em] text-espresso text-sm md:text-base hidden sm:inline">
        HONEYMOON
      </span>
    </a>

    <nav aria-label="Primary" class="hidden md:flex items-center gap-7 text-sm font-semibold tracking-wide">
      {NAV.filter(n => n.href !== '/booking').map(item => (
        <a
          href={url(item.href)}
          class:list={[
            'transition-colors hover:text-honey',
            isActive(item.href) ? 'text-honey' : 'text-espresso/80',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a href={bookingMailto()} class="btn btn-primary text-xs md:text-sm">
      Book us
    </a>
  </div>

  <details class="md:hidden border-t border-honey/15 bg-cream">
    <summary class="container-narrow flex items-center justify-between py-3 cursor-pointer list-none">
      <span class="text-xs uppercase tracking-[0.2em] font-semibold text-espresso/70">Menu</span>
      <span class="text-honey">+</span>
    </summary>
    <nav aria-label="Mobile" class="container-narrow flex flex-col py-2 pb-4 gap-1 text-sm font-semibold">
      {NAV.map(item => (
        <a
          href={url(item.href)}
          class:list={[
            'py-2 transition-colors hover:text-honey',
            isActive(item.href) ? 'text-honey' : 'text-espresso/80',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </details>
</header>
