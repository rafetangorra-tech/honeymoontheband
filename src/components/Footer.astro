---
import { SITE, NAV } from '~/data/site';
import { url } from '~/lib/url';
const year = new Date().getFullYear();
---

<footer class="bg-espresso text-cream/85 mt-24">
  <div class="container-narrow py-14 grid gap-10 md:grid-cols-12">
    <div class="md:col-span-5">
      <div class="flex items-center gap-3">
        <img src={url('/favicons/apple-touch-icon.png')} alt="Honeymoon" width="48" height="48" class="h-12 w-12 brightness-110" />
        <span class="font-bold tracking-[0.2em] text-cream">HONEYMOON</span>
      </div>
      <p class="mt-4 text-sm leading-relaxed max-w-md">
        {SITE.defaultDescription}
      </p>
    </div>

    <div class="md:col-span-2">
      <p class="eyebrow !text-honey">Explore</p>
      <ul class="mt-3 space-y-2 text-sm">
        {NAV.map(n => (
          <li><a href={url(n.href)} class="hover:text-honey transition-colors">{n.label}</a></li>
        ))}
        <li><a href={url('/music')} class="hover:text-honey transition-colors">Music</a></li>
      </ul>
    </div>

    <div class="md:col-span-2">
      <p class="eyebrow !text-honey">Service Areas</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href={url('/wedding-band-nyc')} class="hover:text-honey transition-colors">Wedding Band NYC</a></li>
        <li><a href={url('/wedding-band-long-island')} class="hover:text-honey transition-colors">Long Island</a></li>
        <li><a href={url('/wedding-band-westchester')} class="hover:text-honey transition-colors">Westchester</a></li>
        <li><a href={url('/corporate-event-band')} class="hover:text-honey transition-colors">Corporate Events</a></li>
      </ul>
    </div>

    <div class="md:col-span-3">
      <p class="eyebrow !text-honey">Resources & Contact</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href={url('/blog')} class="hover:text-honey transition-colors">Blog</a></li>
        <li><a href={url('/live-band-vs-dj')} class="hover:text-honey transition-colors">Live band vs. DJ</a></li>
        <li><a href={url('/epk')} class="hover:text-honey transition-colors">EPK / Press kit</a></li>
        <li><a href={`mailto:${SITE.email}`} class="hover:text-honey transition-colors break-all">{SITE.email}</a></li>
        <li><a href={SITE.socials.instagram} class="hover:text-honey transition-colors" rel="noopener" target="_blank">Instagram</a></li>
        <li><a href={SITE.socials.facebook} class="hover:text-honey transition-colors" rel="noopener" target="_blank">Facebook</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-cream/10">
    <div class="container-narrow py-5 text-xs text-cream/60 flex flex-col md:flex-row gap-2 justify-between items-center">
      <span>© {year} Honeymoon the Band</span>
      <span>{SITE.tagline}</span>
    </div>
  </div>
</footer>
