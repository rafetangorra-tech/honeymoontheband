---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { SITE, CONFIGURATIONS, bookingMailto } from '~/data/site';
import { bandPhoto } from '~/data/photos';
import { url } from '~/lib/url';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Live Wedding Band — Westchester County',
  serviceType: 'Live wedding band',
  provider: {
    '@type': 'MusicGroup',
    name: 'Honeymoon',
    url: SITE.url,
    email: SITE.email,
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Westchester County, New York',
  },
};
---

<BaseLayout
  title="Wedding Band Westchester County | Honeymoon — Live Six-Piece"
  description="Live six-piece wedding band serving Westchester County, NY. Honeymoon brings two lead vocalists and a deep song list to weddings from Tarrytown to Bedford."
  jsonLd={jsonLd}
>
  <section class="bg-espresso text-cream relative overflow-hidden">
    <Image
      src={bandPhoto}
      alt="Honeymoon performing live"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      formats={['avif', 'webp']}
      loading="eager"
      class="absolute inset-0 h-full w-full object-cover opacity-25"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-espresso/80 via-espresso/90 to-espresso"></div>
    <div class="container-narrow relative py-24 md:py-32 text-center">
      <p class="eyebrow">Live Wedding Band</p>
      <h1 class="mt-4 text-4xl md:text-5xl font-extrabold tracking-tight leading-[1.1]">
        Westchester weddings,<br/>done right.
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-cream/85 leading-relaxed">
        Honeymoon plays weddings throughout <strong class="text-cream">Westchester County</strong> — from Tarrytown estates and Hudson Valley vineyards to Bedford barns and country clubs. Six-piece live, two lead vocals, professional sound.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href={url('/booking')} class="btn btn-primary">Check our availability</a>
        <a href={url('/song-list')} class="btn btn-ghost">See the song list</a>
      </div>
    </div>
  </section>

  <section class="container-narrow py-20">
    <div class="max-w-3xl">
      <p class="eyebrow">Built for the Hudson Valley</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold">Pro live music, with the polish your venue expects.</h2>
      <p class="mt-6 leading-relaxed text-espresso/85">
        Westchester venues run the full range — historic estates with strict sound limits, modern country clubs with their own preferred-vendor lists, vineyards and barns where the band is the room. Honeymoon brings the kind of show that fits all of them: tight charts, clean transitions, and a song list that moves a Westchester crowd from cocktail hour to last call.
      </p>
      <p class="mt-4 leading-relaxed text-espresso/85">
        We coordinate directly with your venue on load-in, sound, and run-of-show, and we travel from the Tristate base to wherever your event is.
      </p>
    </div>
  </section>

  <section class="bg-white border-y border-honey/15 py-16">
    <div class="container-narrow">
      <h2 class="text-2xl md:text-3xl font-bold">Three configurations</h2>
      <div class="mt-8 grid md:grid-cols-3 gap-6">
        {CONFIGURATIONS.map(c => (
          <div class="border border-honey/20 p-6 bg-cream">
            <h3 class="font-bold text-lg">{c.name}</h3>
            <p class="mt-3 text-sm text-espresso/80 leading-relaxed">{c.summary}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-narrow py-20 text-center">
    <h2 class="text-2xl md:text-3xl font-bold">Westchester date in mind?</h2>
    <p class="mt-4 max-w-xl mx-auto text-espresso/80">
      Tell us your venue, date, and configuration — we'll send pricing and availability.
    </p>
    <div class="mt-8">
      <a href={url('/booking')} class="btn btn-primary">Book Honeymoon</a>
    </div>
    <p class="mt-6 text-sm text-espresso/60">
      Also serving <a href={url('/wedding-band-nyc')} class="underline decoration-honey hover:text-honey">NYC</a>, <a href={url('/wedding-band-long-island')} class="underline decoration-honey hover:text-honey">Long Island</a>, and <a href={url('/corporate-event-band')} class="underline decoration-honey hover:text-honey">corporate events</a>.
    </p>
  </section>
</BaseLayout>
