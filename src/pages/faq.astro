---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { FAQ } from '~/data/faq';
import { SITE, bookingMailto } from '~/data/site';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Honeymoon FAQ — Booking, Pricing, Logistics"
  description="Answers to common questions about booking Honeymoon for weddings and private events in NYC, Long Island, and Westchester."
  jsonLd={jsonLd}
>
  <section class="container-narrow pt-16 pb-10">
    <p class="eyebrow">FAQ</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight">Frequently asked.</h1>
    <p class="mt-6 text-lg text-espresso/85 max-w-2xl leading-relaxed">
      The questions we get most often. Don't see yours? Email
      <a href={`mailto:${SITE.email}`} class="text-honey hover:underline underline-offset-4">{SITE.email}</a>.
    </p>
  </section>

  <section class="container-narrow pb-16 space-y-3">
    {FAQ.map((f, i) => (
      <details class="group bg-white border border-honey/20 open:border-honey transition-colors">
        <summary class="flex items-center justify-between gap-4 cursor-pointer list-none p-5">
          <span class="font-semibold text-base md:text-lg">{f.q}</span>
          <span class="text-honey text-xl font-light group-open:rotate-45 transition-transform">+</span>
        </summary>
        <div class="px-5 pb-5 text-espresso/80 leading-relaxed">{f.a}</div>
      </details>
    ))}
  </section>

  <section class="bg-espresso text-cream py-14">
    <div class="container-narrow text-center">
      <h2 class="text-2xl md:text-3xl font-bold">Ready to book?</h2>
      <div class="mt-8">
        <a href={bookingMailto()} class="btn btn-primary">Email {SITE.email}</a>
      </div>
    </div>
  </section>
</BaseLayout>
