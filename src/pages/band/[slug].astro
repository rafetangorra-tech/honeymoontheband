---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { SITE, bookingMailto } from '~/data/site';

export async function getStaticPaths() {
  const bios = await getCollection('bios');
  return bios.map(bio => ({
    params: { slug: bio.data.slug },
    props: { bio },
  }));
}

const { bio } = Astro.props;
const { Content } = await render(bio);

const allBios = (await getCollection('bios')).sort((a, b) => a.data.order - b.data.order);
const others = allBios.filter(b => b.data.slug !== bio.data.slug);

const imageBase = bio.data.slug.split('-')[0];
const imageURL = `/img/members/${imageBase === 'alex' ? 'alexandra' : imageBase}.jpg`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: bio.data.name,
  jobTitle: bio.data.role,
  memberOf: {
    '@type': 'MusicGroup',
    name: 'Honeymoon',
    url: SITE.url,
  },
  image: `${SITE.url}${imageURL}`,
  url: `${SITE.url}/band/${bio.data.slug}`,
};
---

<BaseLayout
  title={`${bio.data.name}, ${bio.data.role} — Honeymoon`}
  description={`${bio.data.name} — ${bio.data.role} in Honeymoon, the NY Tristate live wedding & event band.`}
  ogImage={imageURL}
  jsonLd={jsonLd}
>
  <section class="container-narrow pt-12 pb-6">
    <a href="/band" class="text-sm font-semibold uppercase tracking-[0.16em] text-honey hover:underline underline-offset-4">
      ← The Band
    </a>
  </section>

  <article class="container-narrow grid md:grid-cols-[2fr_3fr] gap-10 pb-16">
    <div>
      <div class="aspect-[4/5] bg-espresso/5 overflow-hidden border border-honey/15">
        <img src={imageURL} alt={`${bio.data.name}, ${bio.data.role}`} class="h-full w-full object-cover object-top" />
      </div>
    </div>
    <div>
      <p class="eyebrow">{bio.data.role}</p>
      <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight">{bio.data.name}</h1>
      <div class="mt-8 prose-honeymoon">
        <Content />
      </div>
      <div class="mt-10">
        <a href={bookingMailto(`Booking — Honeymoon (with ${bio.data.name})`)} class="btn btn-primary">Book Honeymoon</a>
      </div>
    </div>
  </article>

  <section class="bg-white border-t border-honey/15 py-14">
    <div class="container-narrow">
      <p class="eyebrow">More of the band</p>
      <ul class="mt-6 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
        {others.map(o => (
          <li>
            <a href={`/band/${o.data.slug}`} class="block group">
              <span class="block font-semibold group-hover:text-honey transition-colors">{o.data.name}</span>
              <span class="block text-xs text-espresso/60 uppercase tracking-wider mt-1">{o.data.role}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
