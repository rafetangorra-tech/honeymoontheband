---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SONG_LIST } from '~/data/song-list';
import { SITE, bookingMailto } from '~/data/site';

const totalSongs = SONG_LIST.reduce((sum, g) => sum + g.songs.length, 0);
---

<BaseLayout
  title="Honeymoon Song List — Wedding & Event Band Repertoire"
  description="Honeymoon's full repertoire across pop, rock, Motown, disco, country, Latin, and ceremony ballads. Updated regularly."
>
  <section class="container-narrow pt-16 pb-8">
    <p class="eyebrow">Repertoire</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight">Honeymoon Song List</h1>
    <p class="mt-6 text-lg leading-relaxed text-espresso/85 max-w-2xl">
      {totalSongs}+ songs across pop, rock, Motown, disco, country, Latin, and ceremony ballads. We update this regularly and learn new songs on request.
    </p>
  </section>

  <section class="container-narrow pb-12">
    <nav aria-label="Genres" class="flex flex-wrap gap-2 text-xs font-semibold uppercase tracking-wider">
      {SONG_LIST.map(g => (
        <a href={`#${g.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`} class="px-3 py-2 border border-honey/40 text-espresso/80 hover:bg-honey hover:text-espresso transition-colors">
          {g.name}
        </a>
      ))}
    </nav>
  </section>

  <section class="container-narrow pb-16 space-y-14">
    {SONG_LIST.map(g => (
      <div id={g.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>
        <h2 class="text-2xl md:text-3xl font-bold border-b border-honey/30 pb-3">{g.name}</h2>
        <ul class="mt-6 grid sm:grid-cols-2 gap-x-10 gap-y-2">
          {g.songs.map(s => (
            <li class="flex justify-between gap-4 border-b border-honey/10 py-2 text-sm">
              <span class="font-medium">{s.title}</span>
              <span class="text-espresso/60 text-right">{s.artist}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>

  <section class="bg-espresso text-cream py-14">
    <div class="container-narrow text-center">
      <h2 class="text-2xl md:text-3xl font-bold">Don't see your song?</h2>
      <p class="mt-4 max-w-lg mx-auto text-cream/80">
        We learn new songs for clients all the time. Send us your must-play list with your booking inquiry.
      </p>
      <div class="mt-8">
        <a href={bookingMailto('Honeymoon Song Request')} class="btn btn-primary">Email {SITE.email}</a>
      </div>
    </div>
  </section>
</BaseLayout>
