---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SONG_LIST } from '~/data/song-list';
import { SITE } from '~/data/site';
import { url } from '~/lib/url';

const totalSongs = SONG_LIST.reduce((sum, g) => sum + g.songs.length, 0);
const slugify = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-');
---

<BaseLayout
  title="Honeymoon Song List — Wedding & Event Band Repertoire"
  description="Honeymoon's full repertoire across pop, rock, Motown, disco, country, Latin, and ceremony ballads. Updated regularly and searchable."
>
  <section class="container-narrow pt-16 pb-6">
    <p class="eyebrow">Repertoire</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight">Honeymoon Song List</h1>
    <p class="mt-6 text-lg leading-relaxed text-espresso/85 max-w-2xl">
      {totalSongs}+ songs across pop, rock, Motown, disco, country, Latin, and ceremony ballads. We update this regularly and learn new songs on request.
    </p>
  </section>

  <section class="container-narrow pb-6">
    <label class="block">
      <span class="block text-xs uppercase tracking-wider font-semibold text-honey mb-2">Search</span>
      <div class="relative">
        <input
          type="search"
          id="song-search"
          placeholder="Search title or artist…"
          autocomplete="off"
          class="w-full border border-honey/30 bg-cream/40 px-4 py-3 pr-12 focus:outline-none focus:border-honey focus:bg-white transition-colors"
        />
        <span
          id="song-search-count"
          class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-espresso/60 font-medium pointer-events-none"
          data-default-count={totalSongs}
        >
          {totalSongs} songs
        </span>
      </div>
    </label>
  </section>

  <section class="container-narrow pb-12">
    <nav aria-label="Genres" id="genre-nav" class="flex flex-wrap gap-2 text-xs font-semibold uppercase tracking-wider">
      {SONG_LIST.map(g => (
        <a href={`#${slugify(g.name)}`} class="px-3 py-2 border border-honey/40 text-espresso/80 hover:bg-honey hover:text-espresso transition-colors">
          {g.name}
        </a>
      ))}
    </nav>
  </section>

  <section class="container-narrow pb-16 space-y-14" id="song-sections">
    {SONG_LIST.map(g => (
      <div id={slugify(g.name)} data-genre-section>
        <h2 class="text-2xl md:text-3xl font-bold border-b border-honey/30 pb-3">{g.name}</h2>
        <ul class="mt-6 grid sm:grid-cols-2 gap-x-10 gap-y-2">
          {g.songs.map(s => (
            <li
              class="flex justify-between gap-4 border-b border-honey/10 py-2 text-sm"
              data-song
              data-haystack={`${s.title.toLowerCase()} ${s.artist.toLowerCase()}`}
            >
              <span class="font-medium">{s.title}</span>
              <span class="text-espresso/60 text-right">{s.artist}</span>
            </li>
          ))}
        </ul>
        <p class="mt-4 text-sm text-espresso/60 italic hidden" data-no-results-in-section>No matches in this genre.</p>
      </div>
    ))}
    <p id="no-results" class="hidden text-center text-espresso/70 py-12">
      No songs match your search. <a href="#" id="clear-search" class="text-honey font-semibold underline underline-offset-4">Clear and start over</a>
    </p>
  </section>

  <section class="bg-espresso text-cream py-14">
    <div class="container-narrow text-center">
      <h2 class="text-2xl md:text-3xl font-bold">Don't see your song?</h2>
      <p class="mt-4 max-w-lg mx-auto text-cream/80">
        We learn new songs for clients all the time. Send us your must-play list with your booking inquiry.
      </p>
      <div class="mt-8">
        <a href={url('/booking')} class="btn btn-primary">Book Honeymoon</a>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const input = document.getElementById('song-search');
      const countEl = document.getElementById('song-search-count');
      const sections = document.querySelectorAll('[data-genre-section]');
      const noResults = document.getElementById('no-results');
      const clearLink = document.getElementById('clear-search');
      if (!input) return;

      const defaultCount = countEl ? Number(countEl.dataset.defaultCount || '0') : 0;

      const filter = () => {
        const q = input.value.trim().toLowerCase();
        let visibleTotal = 0;

        sections.forEach(section => {
          const songs = section.querySelectorAll('[data-song]');
          let visibleInSection = 0;
          songs.forEach(li => {
            const hay = li.dataset.haystack || '';
            const match = !q || hay.includes(q);
            li.classList.toggle('hidden', !match);
            if (match) visibleInSection++;
          });
          visibleTotal += visibleInSection;
          const empty = section.querySelector('[data-no-results-in-section]');
          if (empty) empty.classList.toggle('hidden', visibleInSection > 0 || !q);
          section.classList.toggle('opacity-40', visibleInSection === 0 && q.length > 0);
        });

        if (countEl) {
          countEl.textContent = q
            ? `${visibleTotal} match${visibleTotal === 1 ? '' : 'es'}`
            : `${defaultCount} songs`;
        }
        if (noResults) noResults.classList.toggle('hidden', visibleTotal > 0 || !q);
      };

      input.addEventListener('input', filter);

      if (clearLink) {
        clearLink.addEventListener('click', e => {
          e.preventDefault();
          input.value = '';
          filter();
          input.focus();
        });
      }
    })();
  </script>
</BaseLayout>
