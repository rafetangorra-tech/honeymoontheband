---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { SITE, CONFIGURATIONS, bookingMailto } from '~/data/site';
import { bandPhoto } from '~/data/photos';
import { url } from '~/lib/url';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Corporate Event & Gala Band',
  serviceType: 'Live corporate event band',
  provider: {
    '@type': 'MusicGroup',
    name: 'Honeymoon',
    url: SITE.url,
    email: SITE.email,
  },
  areaServed: ['New York City', 'Long Island', 'Westchester County', 'New Jersey', 'Connecticut'],
};
---

<BaseLayout
  title="Corporate Event Band NYC | Honeymoon — Galas, Holiday Parties, Launches"
  description="Honeymoon is a six-piece live band for corporate events, galas, holiday parties, and brand activations across NYC and the Tristate. Pro show, deep repertoire, easy to work with."
  jsonLd={jsonLd}
>
  <section class="bg-espresso text-cream relative overflow-hidden">
    <Image
      src={bandPhoto}
      alt="Honeymoon performing live"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      formats={['avif', 'webp']}
      loading="eager"
      class="absolute inset-0 h-full w-full object-cover opacity-25"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-espresso/80 via-espresso/90 to-espresso"></div>
    <div class="container-narrow relative py-24 md:py-32 text-center">
      <p class="eyebrow">Corporate Events & Galas</p>
      <h1 class="mt-4 text-4xl md:text-5xl font-extrabold tracking-tight leading-[1.1]">
        Live music<br/>for events that matter.
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-cream/85 leading-relaxed">
        Honeymoon plays galas, holiday parties, brand activations, and corporate events across the New York Tristate — six-piece live, two lead vocals, and a show calibrated to the room.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href={bookingMailto('Honeymoon — Corporate Event Inquiry')} class="btn btn-primary">Get a quote</a>
        <a href={url('/song-list')} class="btn btn-ghost">See the song list</a>
      </div>
    </div>
  </section>

  <section class="container-narrow py-20">
    <div class="max-w-3xl">
      <p class="eyebrow">What we do for corporate clients</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold">Easy to brief. Easy to work with. Hard to forget.</h2>
      <p class="mt-6 leading-relaxed text-espresso/85">
        We've played the full corporate spectrum — black-tie galas, holiday parties, product launches, sales kickoffs, conference after-parties, brand experiences. We arrive on time, run sound cleanly, hit your run-of-show to the minute, and play a set that fits whatever your audience actually wants to hear.
      </p>
      <p class="mt-4 leading-relaxed text-espresso/85">
        Need a tighter footprint? We'll bring a smaller configuration. Want bigger? Add horns. Pairing live with a DJ for transitions and a dance set? That's our band + DJ hybrid.
      </p>
    </div>
  </section>

  <section class="bg-white border-y border-honey/15 py-16">
    <div class="container-narrow">
      <h2 class="text-2xl md:text-3xl font-bold">Event types we cover</h2>
      <ul class="mt-6 grid sm:grid-cols-2 gap-3 text-espresso/85">
        <li class="flex gap-2"><span class="text-honey">●</span> Black-tie galas & non-profit fundraisers</li>
        <li class="flex gap-2"><span class="text-honey">●</span> Holiday parties</li>
        <li class="flex gap-2"><span class="text-honey">●</span> Product launches & brand activations</li>
        <li class="flex gap-2"><span class="text-honey">●</span> Sales kickoffs & company-wide events</li>
        <li class="flex gap-2"><span class="text-honey">●</span> Conference welcomes & after-parties</li>
        <li class="flex gap-2"><span class="text-honey">●</span> Private celebrations (anniversaries, milestones)</li>
      </ul>
    </div>
  </section>

  <section class="container-narrow py-20">
    <h2 class="text-2xl md:text-3xl font-bold text-center">Three configurations</h2>
    <div class="mt-10 grid md:grid-cols-3 gap-6">
      {CONFIGURATIONS.map(c => (
        <div class="border border-honey/20 p-6 bg-white">
          <h3 class="font-bold text-lg">{c.name}</h3>
          <p class="mt-3 text-sm text-espresso/80 leading-relaxed">{c.summary}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-espresso text-cream py-16">
    <div class="container-narrow text-center">
      <h2 class="text-2xl md:text-3xl font-bold">Got a brief?</h2>
      <p class="mt-4 max-w-xl mx-auto text-cream/80">
        Send us your event date, venue, and a one-paragraph rundown. We'll respond with availability and pricing.
      </p>
      <div class="mt-8">
        <a href={bookingMailto('Honeymoon — Corporate Event Inquiry')} class="btn btn-primary">Email {SITE.email}</a>
      </div>
      <p class="mt-6 text-sm text-cream/60">
        Also serving weddings in <a href={url('/wedding-band-nyc')} class="underline decoration-honey hover:text-honey">NYC</a>, <a href={url('/wedding-band-long-island')} class="underline decoration-honey hover:text-honey">Long Island</a>, and <a href={url('/wedding-band-westchester')} class="underline decoration-honey hover:text-honey">Westchester</a>.
      </p>
    </div>
  </section>
</BaseLayout>
