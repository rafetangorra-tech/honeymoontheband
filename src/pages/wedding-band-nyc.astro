---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { SITE, CONFIGURATIONS, bookingMailto } from '~/data/site';
import { bandPhoto } from '~/data/photos';
import { url } from '~/lib/url';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Live Wedding Band — New York City',
  serviceType: 'Live wedding band',
  provider: {
    '@type': 'MusicGroup',
    name: 'Honeymoon',
    url: SITE.url,
    email: SITE.email,
  },
  areaServed: {
    '@type': 'City',
    name: 'New York City',
    containsPlace: ['Manhattan', 'Brooklyn', 'Queens', 'The Bronx', 'Staten Island'],
  },
};
---

<BaseLayout
  title="Live Wedding Band NYC | Honeymoon — Manhattan, Brooklyn, Queens"
  description="Honeymoon is a six-piece live wedding band serving New York City — Manhattan, Brooklyn, Queens, and beyond. Two lead vocalists, deep song list, professional show."
  jsonLd={jsonLd}
>
  <section class="bg-espresso text-cream relative overflow-hidden">
    <Image
      src={bandPhoto}
      alt="Honeymoon performing live"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      formats={['avif', 'webp']}
      loading="eager"
      class="absolute inset-0 h-full w-full object-cover opacity-25"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-espresso/80 via-espresso/90 to-espresso"></div>
    <div class="container-narrow relative py-24 md:py-32 text-center">
      <p class="eyebrow">Live Wedding Band</p>
      <h1 class="mt-4 text-4xl md:text-5xl font-extrabold tracking-tight leading-[1.1]">
        New York City weddings.<br/>Six-piece live band.
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-cream/85 leading-relaxed">
        Honeymoon plays weddings across <strong class="text-cream">Manhattan, Brooklyn, Queens, the Bronx, and Staten Island</strong> — built for the rooms, the timelines, and the energy New York couples expect.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href={bookingMailto('Honeymoon — NYC Wedding Inquiry')} class="btn btn-primary">Check our availability</a>
        <a href={url('/song-list')} class="btn btn-ghost">See the song list</a>
      </div>
    </div>
  </section>

  <section class="container-narrow py-20">
    <div class="max-w-3xl">
      <p class="eyebrow">Why Honeymoon for your NYC wedding</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold">A live show your guests will actually remember.</h2>
      <p class="mt-6 leading-relaxed text-espresso/85">
        New York wedding venues are demanding. Tight load-ins. Strict end times. Rooms that range from intimate downtown lofts to ballrooms that seat 400. Honeymoon is built for all of it — two lead vocalists, a tight rhythm section, and the kind of repertoire that keeps a Manhattan crowd dancing without needing to "warm up."
      </p>
      <p class="mt-4 leading-relaxed text-espresso/85">
        We cover the full event arc: ceremony, cocktail hour, reception, late-night. Or just the reception, if that's what your venue contract allows.
      </p>
    </div>
  </section>

  <section class="bg-white border-y border-honey/15 py-16">
    <div class="container-narrow">
      <h2 class="text-2xl md:text-3xl font-bold">Three ways we show up</h2>
      <div class="mt-8 grid md:grid-cols-3 gap-6">
        {CONFIGURATIONS.map(c => (
          <div class="border border-honey/20 p-6 bg-cream">
            <h3 class="font-bold text-lg">{c.name}</h3>
            <p class="mt-3 text-sm text-espresso/80 leading-relaxed">{c.summary}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-narrow py-20 text-center">
    <h2 class="text-2xl md:text-3xl font-bold">Got an NYC date in mind?</h2>
    <p class="mt-4 max-w-xl mx-auto text-espresso/80">
      Tell us your venue and date — we'll send pricing and availability.
    </p>
    <div class="mt-8">
      <a href={bookingMailto('Honeymoon — NYC Wedding Inquiry')} class="btn btn-primary">Email {SITE.email}</a>
    </div>
    <p class="mt-6 text-sm text-espresso/60">
      Also serving <a href={url('/wedding-band-long-island')} class="underline decoration-honey hover:text-honey">Long Island</a>, <a href={url('/wedding-band-westchester')} class="underline decoration-honey hover:text-honey">Westchester</a>, and <a href={url('/corporate-event-band')} class="underline decoration-honey hover:text-honey">corporate events</a>.
    </p>
  </section>
</BaseLayout>
