---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE, SERVICE_AREAS, CONFIGURATIONS, bookingMailto } from '~/data/site';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicGroup',
  name: 'Honeymoon',
  alternateName: 'Honeymoon the Band',
  url: `${SITE.url}/about`,
  description: SITE.defaultDescription,
  foundingLocation: { '@type': 'Place', name: 'New York Tristate Area' },
  areaServed: SERVICE_AREAS,
};
---

<BaseLayout
  title="About Honeymoon — NY Tristate Wedding & Event Band"
  description="Honeymoon is a six-piece live band serving weddings and private events across NYC, Long Island, and Westchester. Here's who we are."
  jsonLd={jsonLd}
>
  <section class="container-narrow pt-16 pb-8">
    <p class="eyebrow">About</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight">Honeymoon</h1>
    <p class="mt-6 text-lg leading-relaxed text-espresso/85 max-w-2xl">
      Honeymoon is a six-piece live band built for weddings, private events, and corporate parties across the
      <strong>New York Tristate Area</strong>. Two lead vocalists, a tight rhythm section, and a deep song list —
      designed to keep your dance floor full from the first note to the last.
    </p>
  </section>

  <section class="container-narrow py-12 grid md:grid-cols-2 gap-12">
    <div>
      <h2 class="text-2xl font-bold">What we do</h2>
      <p class="mt-4 leading-relaxed text-espresso/80">
        We play the music your guests already love — modern pop, Motown, classic rock, disco, soul, and the ballads
        that make ceremony and first-dance moments land. Our standard show is a high-energy live performance built
        around your event's flow: cocktail hour, dinner, dancing, late-night.
      </p>
      <p class="mt-4 leading-relaxed text-espresso/80">
        We're full-service for the music side of your event. Bring us in for the reception only, or for the whole
        arc — ceremony, cocktail, reception.
      </p>
    </div>

    <div>
      <h2 class="text-2xl font-bold">Where we play</h2>
      <ul class="mt-4 space-y-2 text-espresso/85">
        {SERVICE_AREAS.map(a => (
          <li class="flex gap-2">
            <span class="text-honey">●</span>
            <span>{a}</span>
          </li>
        ))}
      </ul>
      <p class="mt-6 text-sm text-espresso/70">
        Travel beyond the Tristate is available — <a href="/booking" class="text-honey hover:underline underline-offset-4">reach out</a> with your venue and date.
      </p>
    </div>
  </section>

  <section class="bg-white border-y border-honey/15 py-16">
    <div class="container-narrow">
      <h2 class="text-2xl md:text-3xl font-bold">Configurations</h2>
      <p class="mt-3 text-espresso/75 max-w-2xl">Three formats, so the band fits the room.</p>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        {CONFIGURATIONS.map(c => (
          <div class="border border-honey/20 p-6 bg-cream">
            <h3 class="font-bold text-lg">{c.name}</h3>
            <p class="mt-3 text-sm text-espresso/80 leading-relaxed">{c.summary}</p>
          </div>
        ))}
      </div>
      <div class="mt-10">
        <a href="/booking" class="btn btn-ghost">Booking details</a>
      </div>
    </div>
  </section>

  <section class="container-narrow py-20 text-center">
    <h2 class="text-2xl md:text-3xl font-bold">Ready to talk?</h2>
    <p class="mt-4 text-espresso/80">Email us with your date, venue, and a short note about your event.</p>
    <div class="mt-8">
      <a href={bookingMailto()} class="btn btn-primary">{SITE.email}</a>
    </div>
  </section>
</BaseLayout>
