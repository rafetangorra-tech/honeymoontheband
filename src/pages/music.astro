---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE } from '~/data/site';
import { FEATURED_REELS } from '~/data/featured-reels';
---

<BaseLayout
  title="Live Performance Videos — Honeymoon"
  description="Watch Honeymoon live. Featured reels and recent clips from our wedding and event performances."
>
  <section class="container-narrow pt-16 pb-10">
    <p class="eyebrow">Music & Video</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight">Hear &amp; see Honeymoon.</h1>
    <p class="mt-6 text-lg text-espresso/85 max-w-2xl leading-relaxed">
      Featured reels from recent shows. For the latest live clips, follow
      <a href={SITE.socials.instagram} target="_blank" rel="noopener" class="text-honey font-semibold hover:underline underline-offset-4">
        {SITE.igHandle}
      </a>.
    </p>
  </section>

  <section class="container-narrow pb-16">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {FEATURED_REELS.map(reel => (
        <div class="bg-white border border-honey/15 overflow-hidden">
          <div class="relative w-full" style="aspect-ratio: 9/16;">
            <iframe
              src={`https://www.instagram.com/reel/${reel.id}/embed/`}
              title={`Honeymoon reel ${reel.id}`}
              loading="lazy"
              allowtransparency="true"
              allowfullscreen
              scrolling="no"
              referrerpolicy="no-referrer-when-downgrade"
              class="absolute inset-0 w-full h-full"
              style="border: 0;"
            ></iframe>
          </div>
          <div class="px-4 py-3 text-xs uppercase tracking-wider text-espresso/60 border-t border-honey/10 flex justify-between items-center">
            <span>Honeymoon · live</span>
            <a
              href={`https://www.instagram.com/reel/${reel.id}/`}
              target="_blank"
              rel="noopener"
              class="text-honey hover:underline underline-offset-4"
            >
              Open in IG ↗
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-espresso text-cream py-14">
    <div class="container-narrow text-center">
      <h2 class="text-2xl md:text-3xl font-bold">Want more?</h2>
      <p class="mt-4 max-w-xl mx-auto text-cream/80">
        We post live clips regularly. Follow us for the latest.
      </p>
      <div class="mt-8">
        <a href={SITE.socials.instagram} target="_blank" rel="noopener" class="btn btn-primary">
          Follow {SITE.igHandle}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
