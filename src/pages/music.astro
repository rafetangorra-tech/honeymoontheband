---
import BaseLayout from '~/layouts/BaseLayout.astro';
import InstagramEmbed from '~/components/InstagramEmbed.astro';
import { SITE } from '~/data/site';
import { FEATURED_REELS } from '~/data/featured-reels';

const PROMO_VIDEO_ID = 'iSb-UX3FPyQ';
const PROMO_URL = `https://www.youtube.com/watch?v=${PROMO_VIDEO_ID}`;
const PROMO_EMBED = `https://www.youtube-nocookie.com/embed/${PROMO_VIDEO_ID}?rel=0&modestbranding=1&playsinline=1`;
const PROMO_THUMB = `https://i.ytimg.com/vi/${PROMO_VIDEO_ID}/maxresdefault.jpg`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: 'Honeymoon — Live Promo',
  description: "Live performance reel from Honeymoon, the NY Tristate live wedding & event band.",
  thumbnailUrl: PROMO_THUMB,
  contentUrl: PROMO_URL,
  embedUrl: PROMO_EMBED,
  publisher: {
    '@type': 'MusicGroup',
    name: 'Honeymoon',
    url: SITE.url,
  },
};
---

<BaseLayout
  title="Watch Honeymoon Live — Promo Video & Reels"
  description="Watch Honeymoon live. Featured promo video plus reels from recent weddings and events across NYC, Long Island, and Westchester."
  ogImage={PROMO_THUMB}
  jsonLd={jsonLd}
>
  <section class="container-narrow pt-16 pb-8">
    <p class="eyebrow">Music & Video</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight">Hear &amp; see Honeymoon.</h1>
    <p class="mt-6 text-lg text-espresso/85 max-w-2xl leading-relaxed">
      Our promo reel below, plus featured clips from recent shows. For the latest, follow
      <a href={SITE.socials.instagram} target="_blank" rel="noopener" class="text-honey font-semibold hover:underline underline-offset-4">
        {SITE.igHandle}
      </a>.
    </p>
  </section>

  <section class="container-narrow pb-16">
    <div class="bg-espresso border border-honey/20 overflow-hidden">
      <div class="relative w-full" style="aspect-ratio: 16/9;">
        <iframe
          src={PROMO_EMBED}
          title="Honeymoon — Live Promo Video"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          referrerpolicy="strict-origin-when-cross-origin"
          class="absolute inset-0 w-full h-full"
          style="border: 0;"
        ></iframe>
      </div>
      <div class="px-5 py-3 text-xs uppercase tracking-wider text-cream/70 flex justify-between items-center">
        <span>Honeymoon · Promo</span>
        <a
          href={PROMO_URL}
          target="_blank"
          rel="noopener"
          class="text-honey hover:underline underline-offset-4"
        >
          Watch on YouTube ↗
        </a>
      </div>
    </div>
  </section>

  <section class="container-narrow pb-16">
    <p class="eyebrow">Featured reels</p>
    <h2 class="mt-3 text-2xl md:text-3xl font-bold">From recent shows.</h2>
    <p class="mt-3 text-sm text-espresso/60 max-w-xl">
      Reels load from Instagram. If they take a moment, give it a beat — or click through to view directly.
    </p>
    <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-6 items-start">
      {FEATURED_REELS.map(reel => (
        <InstagramEmbed reelId={reel.id} />
      ))}
    </div>
  </section>

  <section class="bg-espresso text-cream py-14">
    <div class="container-narrow text-center">
      <h2 class="text-2xl md:text-3xl font-bold">Want more?</h2>
      <p class="mt-4 max-w-xl mx-auto text-cream/80">
        We post live clips regularly. Follow us for the latest.
      </p>
      <div class="mt-8">
        <a href={SITE.socials.instagram} target="_blank" rel="noopener" class="btn btn-primary">
          Follow {SITE.igHandle}
        </a>
      </div>
    </div>
  </section>

  <script is:inline async src="https://www.instagram.com/embed.js"></script>
</BaseLayout>
