---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE, bookingMailto } from '~/data/site';
import { url } from '~/lib/url';

const steps = [
  {
    n: '01',
    title: 'Inquiry',
    body: 'You email us with your date, venue, and configuration. We reply within 1–2 business days with availability and pricing.',
  },
  {
    n: '02',
    title: 'Quote & questions',
    body: 'We send a custom quote based on your event scope. You ask whatever you need to ask — we are direct, transparent, and happy to get on a call if it helps.',
  },
  {
    n: '03',
    title: 'Contract & deposit',
    body: 'A signed contract and a deposit lock your date. The remaining balance is due before the event.',
  },
  {
    n: '04',
    title: 'Planning meeting',
    body: 'About 4–8 weeks before the event we run a planning call: ceremony music, first dance, must-plays, do-not-plays, run-of-show, attire, and logistics with your venue and planner.',
  },
  {
    n: '05',
    title: 'Run-of-show finalized',
    body: 'We send you a written run-of-show and confirm song choices for each segment — ceremony, cocktail, reception, dances, late-night. You sign off, we lock it.',
  },
  {
    n: '06',
    title: 'Event day',
    body: 'We arrive early, load in, sound check, and play the show you planned. Tight transitions, full energy, on-time wrap.',
  },
  {
    n: '07',
    title: 'After',
    body: 'We follow up the next day. If you want clips for socials we share what we have. Reviews and referrals are always appreciated.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to book and work with Honeymoon for your event',
  description: 'The step-by-step process from inquiry to event day for booking Honeymoon, the NY Tristate live wedding & event band.',
  step: steps.map((s, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: s.title,
    text: s.body,
  })),
};
---

<BaseLayout
  title="How We Work — Honeymoon's Booking & Event Process"
  description="From inquiry to event day: the seven-step process for booking Honeymoon for your wedding or private event. Transparent, professional, and built around your timeline."
  jsonLd={jsonLd}
>
  <section class="container-narrow pt-16 pb-10">
    <p class="eyebrow">How we work</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight">From inquiry to event day.</h1>
    <p class="mt-6 text-lg leading-relaxed text-espresso/85 max-w-2xl">
      No mystery. Here's exactly how booking Honeymoon and planning your event with us actually goes.
    </p>
  </section>

  <section class="container-narrow pb-16 space-y-8">
    {steps.map(s => (
      <div class="grid grid-cols-[auto_1fr] gap-6 md:gap-10 items-start border-b border-honey/15 pb-8 last:border-b-0">
        <div class="text-3xl md:text-5xl font-extrabold text-honey tracking-tight">{s.n}</div>
        <div>
          <h2 class="text-xl md:text-2xl font-bold">{s.title}</h2>
          <p class="mt-3 text-espresso/80 leading-relaxed">{s.body}</p>
        </div>
      </div>
    ))}
  </section>

  <section class="bg-espresso text-cream py-16">
    <div class="container-narrow text-center">
      <h2 class="text-2xl md:text-3xl font-bold">Ready to start?</h2>
      <p class="mt-4 max-w-xl mx-auto text-cream/80">
        Send us your event date, venue, and configuration. We'll come back with a quote within 1–2 business days.
      </p>
      <div class="mt-8">
        <a href={url('/booking')} class="btn btn-primary">Book Honeymoon</a>
      </div>
      <p class="mt-6 text-sm text-cream/60">
        See <a href={url('/booking')} class="underline decoration-honey hover:text-honey">booking details</a> · <a href={url('/faq')} class="underline decoration-honey hover:text-honey">read the FAQ</a>
      </p>
    </div>
  </section>
</BaseLayout>
