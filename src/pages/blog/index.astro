---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { url } from '~/lib/url';

const articles = (await getCollection('articles'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Honeymoon Blog',
  description: 'Practical articles on wedding bands, wedding music planning, and the live event scene in the NY Tristate Area.',
  blogPost: articles.map(a => ({
    '@type': 'BlogPosting',
    headline: a.data.title,
    description: a.data.description,
    datePublished: a.data.publishDate.toISOString(),
    url: `${import.meta.env.PUBLIC_SITE_URL || 'https://www.honeymoontheband.com'}${url(`/blog/${a.id.replace(/\.md$/, '')}`)}`,
  })),
};
---

<BaseLayout
  title="Honeymoon Blog — Wedding Band & Wedding Music Articles"
  description="Practical articles on wedding bands, wedding music planning, song choices, and the live event scene in the NY Tristate Area."
  jsonLd={jsonLd}
>
  <section class="container-narrow pt-16 pb-10">
    <p class="eyebrow">Blog</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight">Wedding music, planned right.</h1>
    <p class="mt-6 text-lg leading-relaxed text-espresso/85 max-w-2xl">
      Practical, opinionated articles from a working NY Tristate wedding band. Read what to actually consider when you're planning the music for your event.
    </p>
  </section>

  <section class="container-narrow pb-20">
    <ul class="divide-y divide-honey/15 border-y border-honey/15">
      {articles.map(article => (
        <li class="py-8">
          <a href={url(`/blog/${article.id.replace(/\.md$/, '')}`)} class="group block">
            <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2">
              <h2 class="text-xl md:text-2xl font-bold group-hover:text-honey transition-colors">
                {article.data.title}
              </h2>
              <time class="text-xs uppercase tracking-wider text-espresso/60 whitespace-nowrap">
                {formatDate(article.data.publishDate)}
              </time>
            </div>
            <p class="mt-3 text-espresso/75 leading-relaxed">
              {article.data.excerpt ?? article.data.description}
            </p>
            <p class="mt-4 text-sm font-semibold text-honey">Read article →</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
