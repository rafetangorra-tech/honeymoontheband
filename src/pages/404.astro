---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found — Honeymoon" noindex>
  <section class="container-narrow py-32 text-center">
    <p class="eyebrow">404</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight">Page not found.</h1>
    <p class="mt-6 text-espresso/75">The page you're looking for isn't here.</p>
    <div class="mt-10">
      <a href="/" class="btn btn-primary">Back to home</a>
    </div>
  </section>
</BaseLayout>
